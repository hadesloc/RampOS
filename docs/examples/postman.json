{
  "info": {
    "_postman_id": "rampos-api-collection",
    "name": "RampOS API Collection",
    "description": "Complete API collection for RampOS - Fiat-Crypto On/Off Ramp Platform.\n\n## Authentication\nAll API requests require:\n- `Authorization: Bearer <API_KEY>` - Your tenant API key\n- `X-Timestamp` - Current timestamp (ISO8601 or Unix timestamp)\n\n## HMAC Signing (for webhooks)\nSome endpoints (like confirm_payin) require HMAC signature verification.\n\n## Rate Limiting\nAPI is rate-limited. Check `X-RateLimit-*` headers in responses.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{API_KEY}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Set current timestamp in ISO8601 format",
          "const now = new Date().toISOString();",
          "pm.request.headers.add({",
          "    key: 'X-Timestamp',",
          "    value: now",
          "});",
          "",
          "// Generate idempotency key for POST requests",
          "if (pm.request.method === 'POST') {",
          "    const idempotencyKey = pm.variables.get('IDEMPOTENCY_KEY') || `idem_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;",
          "    pm.request.headers.add({",
          "        key: 'Idempotency-Key',",
          "        value: idempotencyKey",
          "    });",
          "}",
          "",
          "// HMAC Signing for internal endpoints",
          "const requiresHmac = pm.variables.get('REQUIRES_HMAC');",
          "if (requiresHmac === 'true') {",
          "    const crypto = require('crypto-js');",
          "    const secret = pm.environment.get('HMAC_SECRET');",
          "    const body = pm.request.body ? pm.request.body.raw : '';",
          "    const timestamp = now;",
          "    const method = pm.request.method;",
          "    const path = pm.request.url.getPath();",
          "    ",
          "    const signatureBase = `${method}\\n${path}\\n${timestamp}\\n${body}`;",
          "    const signature = crypto.HmacSHA256(signatureBase, secret).toString(crypto.enc.Hex);",
          "    ",
          "    pm.request.headers.add({",
          "        key: 'X-Signature',",
          "        value: signature",
          "    });",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Extract common response data",
          "if (pm.response.code === 200) {",
          "    const jsonData = pm.response.json();",
          "    ",
          "    // Store intent_id for subsequent requests",
          "    if (jsonData.intentId) {",
          "        pm.environment.set('LAST_INTENT_ID', jsonData.intentId);",
          "    }",
          "    ",
          "    // Store reference_code for pay-in confirmation",
          "    if (jsonData.referenceCode) {",
          "        pm.environment.set('LAST_REFERENCE_CODE', jsonData.referenceCode);",
          "    }",
          "}",
          "",
          "// Check rate limit headers",
          "const remaining = pm.response.headers.get('X-RateLimit-Remaining');",
          "if (remaining && parseInt(remaining) < 10) {",
          "    console.warn('Rate limit nearly exhausted:', remaining, 'requests remaining');",
          "}"
        ]
      }
    }
  ],
