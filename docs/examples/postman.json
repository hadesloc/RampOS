    {
      "name": "Intents",
      "description": "Intent management - Pay-in, Pay-out, and Trade intents",
      "item": [
        {
          "name": "Pay-In",
          "item": [
            {
              "name": "Create Pay-In Intent",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"tenantId\": \"{{TENANT_ID}}\",\n  \"userId\": \"{{USER_ID}}\",\n  \"amountVnd\": 1000000,\n  \"railsProvider\": \"mock\",\n  \"metadata\": {\n    \"orderId\": \"order_123\",\n    \"source\": \"mobile_app\"\n  }\n}"
                },
                "url": {
                  "raw": "{{BASE_URL}}/{{API_VERSION}}/intents/payin",
                  "host": ["{{BASE_URL}}"],
                  "path": ["{{API_VERSION}}", "intents", "payin"]
                },
                "description": "Create a new pay-in intent for user to deposit fiat currency.\n\n**Minimum amount:** 1,000 VND\n\n**Response includes:**\n- `intentId` - Unique intent identifier\n- `referenceCode` - Bank transfer reference code\n- `virtualAccount` - Virtual bank account details (if applicable)\n- `expiresAt` - When the intent expires"
              },
              "response": [
                {
                  "name": "Created",
                  "status": "OK",
                  "code": 200,
                  "header": [
                    {
                      "key": "X-User-Daily-Limit",
                      "value": "50000000"
                    },
                    {
                      "key": "X-User-Daily-Remaining",
                      "value": "49000000"
                    }
                  ],
                  "body": "{\n  \"intentId\": \"intent_payin_abc123\",\n  \"referenceCode\": \"RAMP1234567890\",\n  \"virtualAccount\": {\n    \"bank\": \"Vietcombank\",\n    \"accountNumber\": \"1234567890123\",\n    \"accountName\": \"RAMPOS PAYMENT\"\n  },\n  \"expiresAt\": \"2026-01-23T11:30:00Z\",\n  \"status\": \"PENDING_BANK\"\n}"
                }
              ]
            },
            {
              "name": "Confirm Pay-In (Internal/Webhook)",
              "request": {
                "auth": {
                  "type": "noauth"
                },
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "X-Internal-Secret",
                    "value": "{{INTERNAL_SERVICE_SECRET}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"tenantId\": \"{{TENANT_ID}}\",\n  \"referenceCode\": \"{{LAST_REFERENCE_CODE}}\",\n  \"status\": \"FUNDS_CONFIRMED\",\n  \"bankTxId\": \"VCB20260123123456\",\n  \"amountVnd\": 1000000,\n  \"settledAt\": \"2026-01-23T10:35:00Z\",\n  \"rawPayloadHash\": \"sha256:abc123def456...\"\n}"
                },
                "url": {
                  "raw": "{{BASE_URL}}/{{API_VERSION}}/intents/payin/confirm",
                  "host": ["{{BASE_URL}}"],
                  "path": ["{{API_VERSION}}", "intents", "payin", "confirm"]
                },
                "description": "**Internal endpoint** - Called by rails provider webhook handler.\n\nConfirms that funds have been received for a pay-in intent.\n\nRequires `X-Internal-Secret` header for authentication."
              },
              "response": [
                {
                  "name": "Confirmed",
                  "status": "OK",
                  "code": 200,
                  "body": "{\n  \"intentId\": \"intent_payin_abc123\",\n  \"status\": \"COMPLETED\"\n}"
                }
              ]
            }
          ]
        },
