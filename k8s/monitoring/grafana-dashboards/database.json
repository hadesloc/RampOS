{
  "annotations": {
    "list": []
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "id": 5,
  "links": [],
  "panels": [
    {
      "title": "Active Connections",
      "type": "graph",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "pg_stat_activity_count{datname=\"rampos\"}",
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "title": "Query Latency",
      "type": "graph",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit[5m])",
          "legendFormat": "Commits/sec"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback[5m])",
          "legendFormat": "Rollbacks/sec"
        }
      ]
    },
    {
      "title": "Locks",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "pg_locks_count{datname=\"rampos\"}",
          "legendFormat": "Locks"
        }
      ]
    },
    {
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "pg_stat_database_blks_hit{datname=\"rampos\"} / (pg_stat_database_blks_hit{datname=\"rampos\"} + pg_stat_database_blks_read{datname=\"rampos\"}) * 100",
          "legendFormat": "Hit Ratio %"
        }
      ]
    },
     {
      "title": "Deadlocks",
      "type": "stat",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "increase(pg_stat_database_deadlocks{datname=\"rampos\"}[1h])",
          "legendFormat": "Deadlocks/hr"
        }
      ]
    }
  ],
  "schemaVersion": 27,
  "style": "dark",
  "tags": ["ramp-os", "db"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "RampOS - Database",
  "uid": "rampos-db",
  "version": 1
}
