AuthnSignature\",\"outputs\":[{\"internalType\":\"bool\",\"name\":\"\",\"type\":\"bool\"}],\"stateMutability\":\"view\",\"type\":\"function\"}],\"devdoc\":{\"author\":\"RampOS Team\",\"details\":\"Stores a passkey public key (x, y coordinates) and verifies WebAuthn      P256 signatures. Implements ERC-1271 for smart contract signature      validation, enabling passkey-native wallet flows with ERC-4337. Security considerations:  - Only the owner can update the passkey public key  - Low-s enforcement prevents signature malleability  - Public key coordinates are validated against the P256 field prime  - WebAuthn clientDataJSON and authenticatorData are parsed on-chain\",\"kind\":\"dev\",\"methods\":{\"constructor\":{\"params\":{\"_owner\":\"The initial owner address\"}},\"getPublicKey()\":{\"returns\":{\"x\":\"The x coordinate\",\"y\":\"The y coordinate\"}},\"isValidSignature(bytes32,bytes)\":{\"details\":\"Supports two signature formats:      - Type 0x00 (65 bytes): Raw P256 signature [type(1) || r(32) || s(32)]      - Type 0x01 (variable): WebAuthn signature [type(1) || webauthn_data(...)]\",\"params\":{\"hash\":\"The hash of the data to validate\",\"signature\":\"The signature bytes\"},\"returns\":{\"magicValue\":\"ERC1271_MAGIC_VALUE if valid, 0xffffffff otherwise\"}},\"registerPasskey(uint256,uint256,bytes)\":{\"params\":{\"_credentialId\":\"The WebAuthn credential ID\",\"_pubKeyX\":\"The x coordinate of the P256 public key\",\"_pubKeyY\":\"The y coordinate of the P256 public key\"}},\"transferOwnership(address)\":{\"params\":{\"newOwner\":\"The new owner address\"}},\"updatePasskey(uint256,uint256)\":{\"params\":{\"_newPubKeyX\":\"The new x coordinate\",\"_newPubKeyY\":\"The new y coordinate\"}},\"verifyPasskeySignature(bytes32,uint256,uint256)\":{\"params\":{\"messageHash\":\"The hash that was signed\",\"r\":\"The r component of the ECDSA signature\",\"s\":\"The s component of the ECDSA signature\"},\"returns\":{\"_0\":\"True if the signature is valid\"}},\"verifyWebAuthnSignature(bytes32,bytes)\":{\"details\":\"The signature is encoded as:      abi.encode(bytes authenticatorData, bytes clientDataJSON, uint256 r, uint256 s)      The challenge in clientDataJSON must match the provided hash.\",\"params\":{\"hash\":\"The expected challenge hash\",\"signature\":\"The WebAuthn signature data\"},\"returns\":{\"_0\":\"True if the signature is valid\"}}},\"title\":\"PasskeySigner\",\"version\":1},\"userdoc\":{\"errors\":{\"NotOwner()\":[{\"notice\":\"Errors\"}]},\"events\":{\"PasskeyRegistered(uint256,uint256,bytes)\":{\"notice\":\"Events\"}},\"kind\":\"user\",\"methods\":{\"constructor\":{\"notice\":\"Constructor - sets the initial owner\"},\"credentialId()\":{\"notice\":\"Credential ID for the passkey (WebAuthn)\"},\"getPublicKey()\":{\"notice\":\"Get the passkey public key\"},\"isPasskeySet()\":{\"notice\":\"Whether a passkey has been registered\"},\"isValidSignature(bytes32,bytes)\":{\"notice\":\"ERC-1271 signature validation\"},\"owner()\":{\"notice\":\"Contract owner\"},\"pubKeyX()\":{\"notice\":\"Passkey public key x coordinate\"},\"pubKeyY()\":{\"notice\":\"Passkey public key y coordinate\"},\"registerPasskey(uint256,uint256,bytes)\":{\"notice\":\"Register a passkey public key\"},\"transferOwnership(address)\":{\"notice\":\"Transfer ownership\"},\"updatePasskey(uint256,uint256)\":{\"notice\":\"Update the passkey public key\"},\"verifyPasskeySignature(bytes32,uint256,uint256)\":{\"notice\":\"Verify a raw P256 signature against the stored public key\"},\"verifyWebAuthnSignature(bytes32,bytes)\":{\"notice\":\"Verify a WebAuthn-formatted passkey signature\"}},\"notice\":\"On-chain P256/secp256r1 passkey signature verifier with ERC-1271\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/passkey/PasskeySigner.sol\":\"PasskeySigner\"},\"evmVersion\":\"prague\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":200},\"remappings\":[\":@account-abstraction/contracts/=lib/acc