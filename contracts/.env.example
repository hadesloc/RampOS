# ==============================================================================
# RampOS Contracts Environment Configuration
# ==============================================================================
# SECURITY CRITICAL:
# - Copy this file to .env: cp .env.example .env
# - NEVER commit .env to version control
# - NEVER share private keys
# - Use dedicated deployment wallets (not personal wallets)
# - Rotate deployment keys after use
# ==============================================================================

# Deployer wallet private key (with 0x prefix)
# Generate new wallet: cast wallet new
# For testnet: Get ETH from faucet (https://www.alchemy.com/faucets/base-sepolia)
# NEVER use mainnet keys for testing!
DEPLOYER_PRIVATE_KEY=

# RPC URLs
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# Block Explorer API key for contract verification
# Get from: https://basescan.org/myapikey
BASESCAN_API_KEY=

# ERC-4337 EntryPoint (canonical address, same on all EVM chains)
ENTRY_POINT_ADDRESS=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789

# ==============================================================================
# Deployed Contract Addresses (fill after deployment)
# ==============================================================================
VND_TOKEN_ADDRESS=
ACCOUNT_FACTORY_ADDRESS=
PAYMASTER_ADDRESS=
