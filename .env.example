# ==============================================================================
# RampOS Environment Configuration Template
# ==============================================================================
# SECURITY CRITICAL:
# - NEVER commit .env files to version control
# - Generate ALL secrets using: openssl rand -hex 32 (or -base64 32)
# - Rotate secrets regularly (minimum: every 90 days)
# - Use a secrets manager in production (Vault, AWS Secrets Manager, etc.)
# ==============================================================================

# Database - REQUIRED: Set strong passwords
POSTGRES_USER=rampos
# Generate: openssl rand -hex 32
POSTGRES_PASSWORD=
DATABASE_PASSWORD=
POSTGRES_DB=rampos
RAMPOS__DATABASE__URL=postgres://rampos:${DATABASE_PASSWORD}@rampos-postgres:5432/rampos
RAMPOS__DATABASE__MAX_CONNECTIONS=100
RAMPOS__DATABASE__MIN_CONNECTIONS=10

# Redis - REQUIRED: Set strong password
# Generate: openssl rand -hex 32
REDIS_PASSWORD=
RAMPOS__REDIS__URL=redis://:${REDIS_PASSWORD}@rampos-redis:6379
RAMPOS__REDIS__POOL_SIZE=20

# NATS
RAMPOS__NATS__URL=nats://localhost:4222
RAMPOS__NATS__STREAM_NAME=rampos

# Server
RAMPOS__SERVER__HOST=0.0.0.0
RAMPOS__SERVER__PORT=8080
RAMPOS__SERVER__REQUEST_TIMEOUT_SECS=30

# Webhook
RAMPOS__WEBHOOK__RETRY_MAX_ATTEMPTS=10
RAMPOS__WEBHOOK__RETRY_INITIAL_DELAY_MS=1000
RAMPOS__WEBHOOK__SIGNATURE_TOLERANCE_SECS=300

# Logging
RUST_LOG=info,ramp_api=debug,ramp_core=debug

# Admin Key - REQUIRED: Set strong admin key
# Generate: openssl rand -hex 24
# Format: <key> or <key>:<role> where role is viewer|operator|admin|superadmin
RAMPOS_ADMIN_KEY=

# Encryption key for sensitive data (webhook secrets, etc.)
# Generate: openssl rand -base64 32
RAMPOS_ENCRYPTION_KEY=

# ==============================================================================
# Smart Contracts Configuration
# ==============================================================================

# RPC URLs - Replace with your provider's URLs
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/${ALCHEMY_API_KEY}

# Deployer Private Key - NEVER share, NEVER commit
# Generate new wallet: cast wallet new
DEPLOYER_PRIVATE_KEY=

# ERC-4337 EntryPoint (canonical address, same on all chains)
ENTRY_POINT_ADDRESS=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789

# Paymaster Signer - Private key for signing paymaster operations
PAYMASTER_SIGNER=

# Block Explorer API Keys (for contract verification)
ETHERSCAN_API_KEY=
POLYGONSCAN_API_KEY=
BASESCAN_API_KEY=
