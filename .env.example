# Environment variables for RampOS development
# ⚠️ CRITICAL: Never commit real values!
# Generate secrets using: openssl rand -hex 32
# NEVER commit .env to version control

# Database - REQUIRED: Set a strong password
POSTGRES_USER=rampos
# Generate secrets using: openssl rand -hex 32
POSTGRES_PASSWORD=<GENERATE_NEW_VALUE>
POSTGRES_DB=rampos
RAMPOS__DATABASE__URL=postgres://rampos:${POSTGRES_PASSWORD}@localhost:5432/rampos
RAMPOS__DATABASE__MAX_CONNECTIONS=100
RAMPOS__DATABASE__MIN_CONNECTIONS=10

# Redis
REDIS_PASSWORD=<GENERATE_NEW_VALUE>
RAMPOS__REDIS__URL=redis://:${REDIS_PASSWORD}@localhost:6379
RAMPOS__REDIS__POOL_SIZE=20

# NATS
RAMPOS__NATS__URL=nats://localhost:4222
RAMPOS__NATS__STREAM_NAME=rampos

# Server
RAMPOS__SERVER__HOST=0.0.0.0
RAMPOS__SERVER__PORT=8080
RAMPOS__SERVER__REQUEST_TIMEOUT_SECS=30

# Webhook
RAMPOS__WEBHOOK__RETRY_MAX_ATTEMPTS=10
RAMPOS__WEBHOOK__RETRY_INITIAL_DELAY_MS=1000
RAMPOS__WEBHOOK__SIGNATURE_TOLERANCE_SECS=300

# Logging
RUST_LOG=info,ramp_api=debug,ramp_core=debug

# Admin - REQUIRED: Set a strong admin key
# Format: <key> or <key>:<role> where role is viewer|operator|admin|superadmin
RAMPOS_ADMIN_KEY=CHANGE_ME_GENERATE_SECURE_KEY

# Encryption key for sensitive data (webhook secrets, etc.)
# Generate with: openssl rand -base64 32
RAMPOS_ENCRYPTION_KEY=CHANGE_ME_GENERATE_32_BYTE_KEY

# Smart Contracts (for development)
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

DEPLOYER_PRIVATE_KEY=0x...
ENTRY_POINT_ADDRESS=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789
PAYMASTER_SIGNER=0x...

ETHERSCAN_API_KEY=YOUR_KEY
POLYGONSCAN_API_KEY=YOUR_KEY
