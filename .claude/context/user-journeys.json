{
  "version": "2.0",
  "project": "RampOS UI/UX Refactor",
  "created_at": "2026-02-03",
  "journeys": [
    {
      "id": "J-001",
      "name": "User Registration & Onboarding",
      "actor": "End User (New)",
      "goal": "Create account and get started with RampOS",
      "ui_components_used": [
        "Login Card",
        "Register Form",
        "Button",
        "Input",
        "Alert",
        "KYC Progress"
      ],
      "steps": [
        {
          "step": 1,
          "action": "User lands on portal login page",
          "ui_element": "Login Page",
          "expected_ui": "Centered premium card with RampOS branding, dark background, professional typography"
        },
        {
          "step": 2,
          "action": "User clicks 'Create Account' link",
          "ui_element": "Link",
          "expected_ui": "Smooth transition to register page with matching card design"
        },
        {
          "step": 3,
          "action": "User enters email and accepts terms",
          "ui_element": "Input, Checkbox",
          "expected_ui": "Input with icon, terms checkbox with label, real-time validation"
        },
        {
          "step": 4,
          "action": "User clicks 'Create Account' button",
          "ui_element": "Button",
          "expected_ui": "Button shows loading spinner, then success state"
        },
        {
          "step": 5,
          "action": "User sets up WebAuthn passkey",
          "ui_element": "Dialog",
          "expected_ui": "Browser passkey prompt appears, success toast on completion"
        },
        {
          "step": 6,
          "action": "User redirected to portal dashboard",
          "ui_element": "Portal Dashboard",
          "expected_ui": "Welcome message, KYC banner prompting verification, empty wallet state"
        },
        {
          "step": 7,
          "action": "User clicks 'Verify Now' on KYC banner",
          "ui_element": "Alert, Button",
          "expected_ui": "Alert with icon, prominent CTA button"
        },
        {
          "step": 8,
          "action": "User completes KYC form steps",
          "ui_element": "KYC Progress, Form",
          "expected_ui": "4-step progress indicator, form sections with validation"
        }
      ],
      "success_criteria": [
        "User can register in under 2 minutes",
        "All form validation provides instant feedback",
        "Progress is clearly visible throughout",
        "No page reload during registration flow"
      ]
    },
